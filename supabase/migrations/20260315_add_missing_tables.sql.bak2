CREATE POLICY "rec_history_view" ON recommendation_history FOR SELECT USING (auth.uid() = user_id);
CREATE POLICY "rec_history_insert" ON recommendation_history FOR INSERT WITH CHECK (auth.uid() = user_id);
CREATE POLICY "rec_history_update" ON recommendation_history FOR UPDATE USING (auth.uid() = user_id);

-- RLS Policies: recommendation_tracking
CREATE POLICY "rec_tracking_view" ON recommendation_tracking FOR SELECT USING (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));
CREATE POLICY "rec_tracking_insert" ON recommendation_tracking FOR INSERT WITH CHECK (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));
CREATE POLICY "rec_tracking_update" ON recommendation_tracking FOR UPDATE USING (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));

