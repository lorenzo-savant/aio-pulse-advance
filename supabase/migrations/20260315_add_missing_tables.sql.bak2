CREATE POLICY "export_jobs_view" ON query_export_jobs FOR SELECT USING (auth.uid() = user_id);
CREATE POLICY "export_jobs_insert" ON query_export_jobs FOR INSERT WITH CHECK (auth.uid() = user_id);
CREATE POLICY "export_jobs_update" ON query_export_jobs FOR UPDATE USING (auth.uid() = user_id);
CREATE POLICY "export_jobs_delete" ON query_export_jobs FOR DELETE USING (auth.uid() = user_id);

