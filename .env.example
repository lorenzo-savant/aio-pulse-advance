# ══════════════════════════════════════════════════════════════════════════════
# AEO Pulse — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env.local` and fill in your values.
# NEVER commit `.env.local` to git — it contains secrets.
# For production: use Vercel Environment Variables or Doppler.
#
# Tag legend:
#   [REQUIRED]    App won't start / core feature broken without this
#   [CORE-AI]     At least ONE of the 4 is required for AI visibility features
#   [RECOMMENDED] Strongly suggested; some features degrade without it
#   [OPTIONAL]    Feature-gated — safe to leave blank if you don't use that feature
#   [DEV-ONLY]    Should never be set in production
#
# ── Feature → keys cheat sheet ───────────────────────────────────────────────
#   Database + Auth
#       → NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY + SUPABASE_SERVICE_KEY
#   AI engine monitoring (ChatGPT / Gemini / Perplexity / Claude responses)
#       → OPENAI_API_KEY / GEMINI_API_KEY / PERPLEXITY_API_KEY / ANTHROPIC_API_KEY  (≥1 required)
#   Strategy Advisor (POST /api/advisor) — Groq is PRIMARY, fast & low cost
#       → GROQ_API_KEY  (falls back to GEMINI_API_KEY, then OPENAI_API_KEY)
#   Citation tracking, FAQ, gap detection, Reddit presence — PRIMARY SERP
#       → BRAVE_SEARCH_API_KEY    (Web Search subscription, free 2k/mo)
#       → BRAVE_ANSWER_API_KEY    (Summarizer / Answer subscription, free 2k/mo)
#       (legacy single-key fallback: BRAVE_API_KEYS — feeds both pools)
#   Google AI Overview detection + Knowledge Graph + PAA — NARROW scope
#       → DATAFORSEO_LOGIN + DATAFORSEO_KEY  (+ DATAFORSEO_MONTHLY_CAP_CENTS)
#   Google Search Console sync (organic traffic, keyword rankings)
#       → GSC_ACCESS_TOKEN + GSC_REFRESH_TOKEN  OR  GSC_SERVICE_ACCOUNT_KEY
#         (+ GSC_SITE_URL)
#   Real Core Web Vitals in Content Audit (LCP/CLS/INP)
#       → PAGESPEED_API_KEY  (free, 25k/day; without it PSI is skipped)
#   Email alerts / weekly digests / team invitations
#       → RESEND_API_KEY + RESEND_FROM_EMAIL
#   Billing / credit purchases
#       → STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET
#   Production rate limiting (in-memory fallback in dev)
#       → UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
#   Enterprise OpenAI tenant (alternative to OPENAI_API_KEY)
#       → AZURE_OPENAI_API_KEY + AZURE_OPENAI_ENDPOINT + AZURE_OPENAI_DEPLOYMENT_NAME
#   Alternative SERP scraping (rare — most setups don't need this)
#       → BRIGHT_DATA_API_KEY  (+ BRIGHT_DATA_DEFAULT_DATASET_ID)
#   Secondary AEO Supabase sync (rare — only if you mirror to another project)
#       → AEO_SUPABASE_URL + AEO_SUPABASE_KEY (+ public twins)
# ══════════════════════════════════════════════════════════════════════════════


# ─── Supabase (Database + Auth) ─────────────────────────────────── [REQUIRED]
# Get from https://supabase.com/dashboard/project/_/settings/api
#   NEXT_PUBLIC_SUPABASE_URL       : Project URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  : "anon / public" API key
#   SUPABASE_SERVICE_KEY           : "service_role" key (SECRET — bypasses RLS)
# A handful of modules also accept SUPABASE_SERVICE_ROLE_KEY as a fallback name.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project reference ID (the subdomain of NEXT_PUBLIC_SUPABASE_URL —
# e.g. for https://abcd1234.supabase.co the ref is "abcd1234").
# Used by `npm run db:gen-types` to regenerate src/types/database.ts.
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF


# ─── App Configuration ──────────────────────────────────────────── [REQUIRED]
# Base URL used in emails, redirects, OAuth callbacks, and webhook URLs.
# Also the primary allowed CORS origin for /api/* (handled in src/middleware.ts).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: extra allowed CORS origins for /api/* (comma-separated), in addition
# to NEXT_PUBLIC_APP_URL and *.vercel.app previews. Leave empty if not needed.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com


# ─── Cron Jobs & Security Secrets ───────────────────────────────── [REQUIRED]
# Vercel auto-injects `Authorization: Bearer <CRON_SECRET>` into cron calls only
# when the var is named exactly CRON_SECRET. verifyCronAuth accepts CRON_SECRET
# OR the legacy CRON_SECRET_TOKEN — prefer setting CRON_SECRET as the single
# source of truth. See docs/runbooks/SECRETS_ROTATION.md.
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Authenticates /api/cron/* endpoints (monitoring, digest, weekly-review, …).
CRON_SECRET_TOKEN=your-secret-random-token-here

# Encrypts user-stored API keys in Supabase (`user_api_keys` table).
ENCRYPTION_KEY=your-64-character-hex-string-here

# HMAC-SHA256 secret for outbound webhook deliveries.
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret


# ─── Core AI Providers — 4-Engine Stack ───────────────────────────── [CORE-AI]
# You need at least ONE of these for AI visibility / monitoring features.
# Recommended: configure all 4 for full engine coverage.

# ChatGPT (OpenAI) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Perplexity — https://www.perplexity.ai/account/api/keys
PERPLEXITY_API_KEY=pplx-...

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...


# ─── Groq (Strategy Advisor PRIMARY) ──────────────────────────── [RECOMMENDED]
# Backend for the Strategy Advisor at POST /api/advisor and the
# /dashboard/advisor page. Llama 3.3 70B / Mixtral / Gemma — fast, low
# cost, generous free tier (~30 req/min, ~6k tokens/min).
#
# Without GROQ_API_KEY the advisor still works by falling back through
# Gemini → OpenAI, but Groq is preferred because it's cheapest + fastest
# for the structured-JSON output the advisor needs.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...


# ─── Market / Locale Configuration ────────────────────────────────── [OPTIONAL]
# Defaults target the Swedish market. Override only if you operate in a
# different region. See src/lib/geo-config.ts for the full list.
# AIO_MARKET_NAME=Sweden
# AIO_LANGUAGE_NAME=Swedish
# AIO_LANGUAGE_CODE=sv
# AIO_COLLECTION_REGION=Stockholm, Sweden (arn1)
# DATAFORSEO_LOCATION_CODE=2752      # DataForSEO numeric location code
# DATAFORSEO_LANGUAGE_CODE=sv        # DataForSEO ISO language code


# ─── Brave Search API — PRIMARY SERP provider ───────────────────── [REQUIRED]
# Per the v2 API strategy (Brave PRIMARY + DataForSEO NARROW SCOPE), Brave is
# the default SERP provider — SerpApi was removed in v2.2.0.
#
# Brave sells two SEPARATE subscriptions, each with its own API key + quota:
#
#   1) "Data for Search" — Web / News / Images / Videos.
#      Powers: citation gap detection, Reddit presence, daily rank tracking,
#      AEO snippets PAA, generic SERP grounding (citation-grounding.ts).
#      Endpoint family: /res/v1/web/search, /res/v1/news/search, …
#      ENV: BRAVE_SEARCH_API_KEY
#
#   2) "Data for AI" / Summarizer — the Answer endpoint that returns a
#      generated reply + citation URLs. "Honest substitute" for Google AI
#      Overview detection.
#      Endpoint: /res/v1/summarizer/search
#      ENV: BRAVE_ANSWER_API_KEY
#
# Free tier on each: 2000 queries/month recurring + 1 query/sec hard cap.
# Both keys are created at https://api.search.brave.com/app/dashboard —
# subscribe to BOTH plans and create one key per plan.
#
# Multi-key pools (rare — for spending isolation): use the plural _KEYS form
# with a comma-separated list. Per-pool monthly cap can be overridden with
# BRAVE_SEARCH_MONTHLY_LIMIT / BRAVE_ANSWER_MONTHLY_LIMIT (same syntax as
# the legacy BRAVE_MONTHLY_LIMIT). Examples:
#   BRAVE_SEARCH_API_KEYS=free_search_key,paid_search_key
#   BRAVE_SEARCH_MONTHLY_LIMIT=2000,10000
#
# BRAVE_SEARCH_API_KEY=
# BRAVE_ANSWER_API_KEY=
# BRAVE_SEARCH_MONTHLY_LIMIT=2000
# BRAVE_ANSWER_MONTHLY_LIMIT=2000
#
# Legacy single-key fallback (still works — feeds both pools when neither
# pool-specific var is set; gets used by both web and summarizer requests):
# BRAVE_API_KEYS=
# BRAVE_MONTHLY_LIMIT=2000


# ─── DataForSEO — Google AI Overview / KG / PAA ──────────────── [RECOMMENDED]
# AEO Pulse = AI Overview Pulse. Google AI Overview accounts for ~80-85% of
# global AI-search traffic. Without DataForSEO the namesake feature does
# not function.
#
# NARROW SCOPE — DataForSEO is invoked ONLY from these wrappers, never
# directly from generic SERP code:
#   • src/lib/services/ai-overview-detector.ts  (Google AI Overview parsing)
#   • src/lib/services/dataforseo-paa.ts        (People Also Ask via DFS)
#   • Future knowledge-graph + keyword-volume wrappers
# Generic SERP / domain rank / Reddit checks go through Brave Search.
# Audit DFS usage quarterly to prevent scope creep.
#
# Sign up at https://dataforseo.com → dashboard at https://app.dataforseo.com
# Pricing: pay-as-you-go (~$0.001-0.003/query); set a dashboard spending
# cap (recommended $20/mo).
# Both fields come from the same place (Basic auth: login + API password).
# DATAFORSEO_LOGIN=your-login@example.com
# DATAFORSEO_KEY=...
#
# Server-side spending cap in cents (mirrors the $20/mo dashboard cap by
# default). Calls beyond this throw DataforseoCapExceeded and degrade
# gracefully. Override to bypass the in-app refuse-when-over-cap gate.
# DATAFORSEO_MONTHLY_CAP_CENTS=2000


# ─── Google Search Console ────────────────────────────────────────── [OPTIONAL]
# Powers the GSC performance sync (organic clicks/impressions/positions).
# Pick ONE auth path:
#
# (A) OAuth user delegation — create an OAuth 2.0 Client ID at
#     https://console.cloud.google.com/apis/credentials and obtain tokens
#     via the OAuth playground (https://developers.google.com/oauthplayground)
#     with scope: https://www.googleapis.com/auth/webmasters.readonly
# GSC_ACCESS_TOKEN=
# GSC_REFRESH_TOKEN=
#
# (B) Service account — create one at
#     https://console.cloud.google.com/iam-admin/serviceaccounts, download
#     the JSON, paste it here (single line, JSON-stringified). Then add the
#     service account email as a User in Search Console.
# GSC_SERVICE_ACCOUNT_KEY=
#
# Verified property URL (exactly as it appears in Search Console).
# GSC_SITE_URL=https://yourdomain.com/


# ─── PageSpeed Insights — real Core Web Vitals ────────────────────── [OPTIONAL]
# Free Google API used by the Content Audit's Performance category to add
# real LCP / CLS / INP signals (not just our server-side TTFB).
#
# WITHOUT a key the audit SKIPS PSI entirely — important to know:
#   PSI from an unauthenticated IP shares a tiny per-IP pool that is almost
#   always exhausted from server platforms (Vercel etc.), so each attempt
#   hangs on the 25s timeout, slowing every audit. The audit still works,
#   but the Performance score falls back to TTFB-only.
#
# WITH a key you get a personal 25,000-requests/day quota — for our use
# case (one PSI call per Content Audit click + a 1h in-memory result cache
# per URL + the route's own 1h audit cache) this is effectively unlimited
# for a small team.
#
# How to get one (free):
#   1. https://console.cloud.google.com → create / select a project
#   2. APIs & Services → Library → enable "PageSpeed Insights API"
#   3. APIs & Services → Credentials → Create credentials → API key
#   4. (Recommended) Restrict the key to PageSpeed Insights API only
# PAGESPEED_API_KEY=


# ─── Stripe (Billing + Credit System) ─────────────────────────────── [OPTIONAL]
# Required only if you enable paid plans / credit purchases.
# Live keys: https://dashboard.stripe.com/apikeys
# Test keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: create an endpoint at https://dashboard.stripe.com/webhooks
#                 and copy the "Signing secret" (whsec_…).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# ─── Email (Resend) ────────────────────────────────────────────────── [OPTIONAL]
# Required for alert emails, weekly digests, team invitations.
# Get your key at https://resend.com/api-keys
# RESEND_FROM_EMAIL must use a verified sender domain in Resend.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=AEO Pulse <alerts@yourdomain.com>


# ─── Upstash Redis (Production Rate Limiting) ──────────────────────── [OPTIONAL]
# Falls back to in-memory rate limiting if blank — fine in dev, but
# UNSAFE on serverless (each cold-start container resets the counter,
# defeating the limit). For Vercel deploys this should be set.
# Free tier at https://console.upstash.com is enough for most projects;
# copy the REST URL + REST Token from the database "REST API" tab.
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=AX...


# ─── Azure OpenAI (enterprise tenant) ─────────────────────────────── [OPTIONAL]
# Alternative path for the OpenAI engine when using an Azure deployment.
# Create the resource + deployment at https://portal.azure.com → Azure OpenAI.
# All three are required together if used.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o


# ─── Bright Data (alternative SERP / scraping) ────────────────────── [OPTIONAL]
# Only used by src/lib/services/brightdata-sync.ts and the brightdata cron.
# Most setups do not need this — Brave + DataForSEO cover all current SERP
# needs. Enable only if you have a specific scraping use case.
# Get an API token at https://brightdata.com/cp/setting/customer
# DATASET_ID is optional — only set if you've created a specific dataset.
# BRIGHT_DATA_API_KEY=
# BRIGHT_DATA_DEFAULT_DATASET_ID=


# ─── AEO Bridge (Secondary Supabase Project) ──────────────────────── [OPTIONAL]
# Only required if you mirror data to an external AEO monitoring Supabase
# project. Same field types as the primary Supabase section above, but from
# a DIFFERENT project at https://supabase.com/dashboard/project/_/settings/api
# Leave blank unless you specifically need this dual-write setup.
# NEXT_PUBLIC_AEO_SUPABASE_URL=https://YOUR_AEO_PROJECT.supabase.co
# NEXT_PUBLIC_AEO_SUPABASE_ANON_KEY=eyJ...
# AEO_SUPABASE_URL=https://YOUR_AEO_PROJECT.supabase.co
# AEO_SUPABASE_KEY=eyJ...


# ─── Dev / Debug Toggles ──────────────────────────────────────────── [DEV-ONLY]
# Dev mode: bypass auth and act as this fixed user ID.
# WARNING: setting this in production triggers a fail-fast guard in
# src/lib/supabase.ts (CF-01). Leave commented for prod.
# DEV_USER_ID=00000000-0000-0000-0000-000000000000

# Developer Bypass credentials (dev only). Read SERVER-SIDE by
# /api/auth/dev-login (which is hard-blocked in production) and powering the
# "Developer Bypass" button on the login page. These are NOT NEXT_PUBLIC_, so
# they are never bundled into the client JS. Use a throwaway demo account and
# set them in .env.local only. Leaving them blank disables the bypass button's
# action (it returns a 400 explaining what to set).
# DEMO_EMAIL=
# DEMO_PASSWORD=

# Log verbosity: trace | debug | info | warn | error
# (default: info in prod, debug in dev). See src/lib/logger.ts.
# LOG_LEVEL=debug

# Dev-only: skip credit deduction in /api/monitoring (handy for load testing).
# Never set in production — there's no other gate against runaway LLM cost.
# ALLOW_CREDIT_BYPASS=true
