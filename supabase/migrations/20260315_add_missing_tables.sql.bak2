CREATE POLICY "keywords_view" ON keyword_tracking FOR SELECT USING (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));
CREATE POLICY "keywords_insert" ON keyword_tracking FOR INSERT WITH CHECK (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));
CREATE POLICY "keywords_update" ON keyword_tracking FOR UPDATE USING (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));

