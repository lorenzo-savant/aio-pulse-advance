CREATE POLICY "competitors_view" ON competitor_analyses FOR SELECT USING (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));
CREATE POLICY "competitors_insert" ON competitor_analyses FOR INSERT WITH CHECK (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));
CREATE POLICY "competitors_delete" ON competitor_analyses FOR DELETE USING (brand_id IN (SELECT id FROM brands WHERE user_id = auth.uid()));

