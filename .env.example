# ══════════════════════════════════════════════════════════════════════════════
# AIO Pulse — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env.local` and fill in your values.
# NEVER commit `.env.local` to git — it contains secrets.
# For production: use Vercel Environment Variables or Doppler.
#
# Legend:
#   [REQUIRED]  App won't start / core feature broken without this
#   [CORE-AI]   At least ONE of the 4 is required for AI visibility features
#   [OPTIONAL]  Feature-gated — safe to leave blank if unused
# ══════════════════════════════════════════════════════════════════════════════


# ─── Supabase (Database + Auth) ─────────────────────────────────── [REQUIRED]
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project reference ID (last segment of NEXT_PUBLIC_SUPABASE_URL,
# e.g. for https://abcd1234.supabase.co the ref is "abcd1234").
# Used by `npm run db:gen-types` to regenerate src/types/database.ts from live schema.
SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Development-only: bypass auth and use this fixed user ID
# WARNING: setting this in production triggers a fail-fast guard in src/lib/supabase.ts (CF-01)
# DEV_USER_ID=00000000-0000-0000-0000-000000000000

# Developer bypass login credentials (dev mode only)
NEXT_PUBLIC_DEMO_EMAIL=demo@aio-pulse.com
NEXT_PUBLIC_DEMO_PASSWORD=Demo1234!


# ─── Core AI Providers — 4-Engine Stack ──────────────────────────── [CORE-AI]
# You need at least ONE of these for AI visibility features to work.
# Recommended: configure all 4 for maximum engine coverage.

# ChatGPT (OpenAI) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...


# ─── Enterprise / Auxiliary AI ────────────────────────────────────── [OPTIONAL]
# Azure OpenAI (enterprise tenant) — all three required together
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# DataForSEO (Google AI Overview scraping) — login + API key both required
# Sign up at https://dataforseo.com
# DATAFORSEO_LOGIN=your-login@example.com
# DATAFORSEO_KEY=...


# ─── Stripe (Billing + Credit System) ──────────────────────────────── [OPTIONAL]
# Required only if you enable paid plans / credit purchases.
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...


# ─── Email (Resend) ────────────────────────────────────────────────── [OPTIONAL]
# Required for alert emails, weekly digests, team invitations.
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AIO Pulse <alerts@yourdomain.com>


# ─── Upstash Redis (Rate Limiting in Production) ───────────────────── [OPTIONAL]
# Falls back to in-memory rate limiting if blank (fine for dev).
# Free tier at https://console.upstash.com is enough for most projects.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...


# ─── App Configuration ──────────────────────────────────────────────── [REQUIRED]
# Base URL used in emails, redirects, and OAuth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Cron Jobs & Security ─────────────────────────────────────────── [REQUIRED]
# Used to authenticate /api/cron/* endpoints (monitoring, digest, weekly-review).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET_TOKEN=your-secret-random-token-here

# Encryption key for user-stored API keys in Supabase (user_api_keys table).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-string-here

# Webhook signing secret for outbound webhook delivery (HMAC-SHA256).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret


# ─── Archive Export System ────────────────────────────────────────── [OPTIONAL]
# Max export file size in bytes (default: 100MB)
MAX_EXPORT_FILESIZE=100000000
# Export job timeout in milliseconds (default: 10 minutes)
EXPORT_JOB_TIMEOUT=600000


# ─── AEO Bridge (Secondary Supabase Project) ──────────────────────── [OPTIONAL]
# Only required if you sync with an external AEO monitoring Supabase project.
# Leave blank unless you know you need this.
# NEXT_PUBLIC_AEO_SUPABASE_URL=https://YOUR_AEO_PROJECT.supabase.co
# NEXT_PUBLIC_AEO_SUPABASE_ANON_KEY=eyJ...
# AEO_SUPABASE_URL=https://YOUR_AEO_PROJECT.supabase.co
# AEO_SUPABASE_KEY=eyJ...
