# PATH: .env.local  (copy this file and fill in your values)
# NEVER commit .env.local to git — it contains secrets.
# For production use Vercel Environment Variables or Doppler.

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Stripe (Billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ─── Anthropic Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── OpenRouter (OpenAI-compatible, many models) ──────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Groq (ultra-fast inference) ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─── Cerebras (free ultra-fast inference) ─────────────────────────────────────
CEREBRAS_API_KEY=csk_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ─── Upstash Redis (rate limiting in production) ──────────────────────────────
# Get from https://console.upstash.com — free tier is enough for most projects
# Leave blank in development — falls back to in-memory rate limiting.
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Archive Export System ────────────────────────────────────────────────────
# Encryption key for API keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-character-hex-string-here
# Cron secret for scheduled jobs (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CRON_SECRET_TOKEN=your-secret-random-token-here
# Max export file size in bytes (default: 100MB)
MAX_EXPORT_FILESIZE=100000000
# Export job timeout in milliseconds (default: 10 minutes)
EXPORT_JOB_TIMEOUT=600000
