{
  "name": "aio-pulse-next",
  "version": "2.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:fix": "npm audit fix",
    "security:check": "npm audit && npm outdated",
    "db:gen-types": "supabase gen types typescript --linked > src/types/database.ts && prettier --write src/types/database.ts",
    "check:deadcode": "npx --node-options=\"--max-old-space-size=4096\" knip",
    "check:prompts": "tsx scripts/audit-prompt-patterns.ts",
    "check:zod": "node scripts/audit-zod-coverage.mjs",
    "check:rls": "node scripts/audit-rls-coverage.mjs",
    "check:all": "npm run check:rls && npm run check:zod && npm run security:audit",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.6.1",
    "apexcharts": "^5.10.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.2.10",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.378.0",
    "next": "^16.2.6",
    "next-intl": "^4.9.1",
    "next-themes": "^0.3.0",
    "papaparse": "^5.5.3",
    "pino": "^9.14.0",
    "react": "^18.3.1",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.7",
    "resend": "^4.8.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "brace-expansion@1": "^1.1.12",
    "brace-expansion@2": "^2.0.2",
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.14",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.1",
    "supabase": "^2.100.1",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
