generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Brand {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  // Fase 1 (T07): workspace/org scoping. NULLABLE during PR 7.1-7.6 transition.
  // NOT NULL enforced in PR 7.7 after backfill.
  workspaceId    String?   @map("workspace_id")
  organizationId String?   @map("organization_id")
  name           String
  slug           String    @unique
  description    String?
  domain         String?
  aliases        String[]  @default([])
  domains        String[]  @default([])
  competitors    String[]  @default([])
  industry       String?
  color          String    @default("#6366f1")
  logoUrl        String?   @map("logo_url")
  // Primary market language — backed by `brands.language` (added in migration
  // 20260413000100_add_brand_language.sql) with a CHECK constraint for the
  // supported codes. Drives localized prompt generation + AEO Snippets locale.
  language       String    @default("en")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  // White-label report settings
  reportLogoUrl      String? @map("report_logo_url")
  reportBrandName    String? @map("report_brand_name")
  reportPrimaryColor String? @map("report_primary_color")

  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  prompts                 Prompt[]
  alertRules              AlertRule[]
  monitoringResults       MonitoringResult[]
  alertEvents             AlertEvent[]
  healthScores            BrandHealthScore[]
  analysisResults         AnalysisResult[]
  competitorAnalyses      CompetitorAnalysis[]
  recommendationHistories RecommendationHistory[]
  citationSnapshots       CitationSnapshot[]
  teamMembers             TeamMember[]
  brandInvitations        BrandInvitation[]
  seoAuditResults         SeoAuditResult[]
  llmsTxtVersions         LlmsTxtVersion[]
  weeklyReviews           WeeklyReview[]
  keywordRankings         KeywordRanking[]
  gscPerformance          GscPerformance[]
  keywordResearch         KeywordResearch[]
  scraperConfigs          ScraperConfig[]
  reportTemplates         ReportTemplate[]
  reportDeliveries        ReportDelivery[]
  aiConversations         AiConversation[]

  @@index([userId])
  @@index([slug])
  @@index([deletedAt])
  @@index([workspaceId])
  @@index([organizationId])
  @@map("brands")
}

model Prompt {
  id           String    @id @default(uuid())
  brandId      String    @map("brand_id")
  userId       String    @map("user_id")
  text         String
  language     String    @default("en")
  market       String    @default("global")
  category     String?
  engines      String[]  @default(["chatgpt", "gemini", "perplexity", "claude"])
  isActive     Boolean   @default(true) @map("is_active")
  runFrequency String    @default("daily") @map("run_frequency")
  lastRunAt    DateTime? @map("last_run_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  brand             Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  monitoringResults MonitoringResult[]

  @@index([brandId])
  @@index([userId])
  @@index([deletedAt])
  @@map("prompts")
}

model MonitoringResult {
  id                 String   @id @default(uuid())
  promptId           String   @map("prompt_id")
  brandId            String   @map("brand_id")
  userId             String   @map("user_id")
  engine             String
  promptText         String   @map("prompt_text")
  responseText       String   @map("response_text")
  brandMentioned     Boolean  @default(false) @map("brand_mentioned")
  mentionPosition    Int?     @map("mention_position")
  mentionCount       Int      @default(0) @map("mention_count")
  mentionType        String?  @map("mention_type")
  visibilityScore    Int      @default(0) @map("visibility_score")
  sentiment          String?
  sentimentScore     Float?   @map("sentiment_score")
  citedUrls          String[] @default([]) @map("cited_urls")
  competitorMentions Json     @default("[]") @map("competitor_mentions")
  hasHallucination   Boolean  @default(false) @map("has_hallucination")
  hallucinationFlags Json     @default("[]") @map("hallucination_flags")
  rawResponse        Json?    @map("raw_response")

  // Execution tracking (Phase 1)
  executionTimeMs    Int?     @map("execution_time_ms")
  costCredits        Float?   @map("cost_credits")
  primaryProvider    String?  @map("primary_provider")
  allProviders       String[] @default([]) @map("all_providers")
  failedProviders    String[] @default([]) @map("failed_providers")
  responseComparison Json?    @map("response_comparison")

  createdAt DateTime @default(now()) @map("created_at")

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([promptId])
  @@index([engine])
  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([primaryProvider])
  @@map("monitoring_results")
}

model AlertRule {
  id          String    @id @default(uuid())
  brandId     String    @map("brand_id")
  userId      String    @map("user_id")
  name        String
  type        String
  condition   Json
  channels    String[]  @default(["email"])
  email       String?
  webhookUrl  String?   @map("webhook_url")
  isActive    Boolean   @default(true) @map("is_active")
  lastFiredAt DateTime? @map("last_fired_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  brand       Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  alertEvents AlertEvent[]

  @@index([brandId])
  @@index([userId])
  @@index([deletedAt])
  @@map("alert_rules")
}

model AlertEvent {
  id           String   @id @default(uuid())
  alertRuleId  String   @map("alert_rule_id")
  brandId      String   @map("brand_id")
  userId       String   @map("user_id")
  type         String
  title        String
  message      String
  data         Json     @default("{}")
  channelsSent String[] @default([]) @map("channels_sent")
  isRead       Boolean  @default(false) @map("is_read")
  createdAt    DateTime @default(now()) @map("created_at")

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  brand     Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brandId])
  @@index([createdAt(sort: Desc)])
  @@index([isRead])
  @@map("alert_events")
}

model BrandHealthScore {
  id                 String   @id @default(uuid())
  brandId            String   @map("brand_id")
  userId             String   @map("user_id")
  date               DateTime @default(now()) @db.Date
  visibilityScore    Float    @default(0) @map("visibility_score")
  sentimentScore     Float    @default(0) @map("sentiment_score")
  hallucinationRate  Float    @default(0) @map("hallucination_rate")
  mentionCount       Int      @default(0) @map("mention_count")
  citationCount      Int      @default(0) @map("citation_count")
  // AVI component metrics
  aviScore           Float    @default(0) @map("avi_score")
  citationRate       Float    @default(0) @map("citation_rate")
  mentionRate        Float    @default(0) @map("mention_rate")
  recommendationRate Float    @default(0) @map("recommendation_rate")
  positionAvg        Float    @default(0) @map("position_avg")
  healthScore        Float    @default(0) @map("health_score")
  engineBreakdown    Json     @default("{}") @map("engine_breakdown")
  createdAt          DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, date])
  @@index([brandId])
  @@index([date(sort: Desc)])
  @@map("brand_health_scores")
}

model Subscription {
  id               String    @id @default(uuid())
  userId           String    @unique @map("user_id")
  stripeCustomerId String?   @map("stripe_customer_id")
  stripeSubId      String?   @map("stripe_sub_id")
  plan             String    @default("free")
  status           String    @default("active")
  currentPeriodEnd DateTime? @map("current_period_end")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("subscriptions")
}

model Credit {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  amount          Int // Credits purchased (positive) or used (negative)
  source          String // 'stripe_purchase', 'promo', 'bonus', 'refund', 'subscription'
  stripePaymentId String?   @map("stripe_payment_id")
  description     String?
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("credits")
}

model CreditUsage {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  queryId     String?  @map("query_id")
  creditsUsed Int // Always positive number
  provider    String? // Which AI provider used
  engine      String? // Which engine (chatgpt, gemini, etc)
  brandId     String?  @map("brand_id")
  description String?
  costCredits Float?   @map("cost_credits") // Calculated cost in credits
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([brandId])
  @@map("credit_usage")
}

model TeamMember {
  id        String   @id @default(uuid())
  brandId   String   @map("brand_id")
  userId    String?  @map("user_id")
  email     String
  role      String   @default("viewer")
  invitedBy String   @map("invited_by")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, email])
  @@index([brandId])
  @@index([userId])
  @@map("team_members")
}

model BrandInvitation {
  id        String   @id @default(uuid())
  brandId   String   @map("brand_id")
  email     String
  role      String   @default("viewer")
  invitedBy String   @map("invited_by")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, email])
  @@index([token])
  @@map("brand_invitations")
}

model ApiKey {
  id             String  @id @default(uuid())
  userId         String  @map("user_id")
  // Fase 1 (T09): org-level + scoped API keys. Nullable during transition.
  organizationId String? @map("organization_id")
  createdBy      String? @map("created_by")
  name           String

  // Legacy: full key stored plaintext. Deprecated by keyHash. Kept until PR 7.7.
  key       String? @unique
  // T09: secure storage — keyPrefix visible (first 16 chars incl. 'aipulse_'),
  // keyHash bcrypt of full key. Both populated by backfill migration.
  keyPrefix String? @map("key_prefix")
  keyHash   String? @unique @map("key_hash")

  // T09: permission model. Empty array = no permissions (deny-all by default).
  // Backfill grants legacy keys all scopes for back-compat.
  scopes String[] @default([])

  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  revokedBy  String?   @map("revoked_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([key])
  @@index([organizationId])
  @@index([keyPrefix])
  @@index([revokedAt])
  @@map("api_keys")
}

model AnalysisResult {
  id              String    @id @default(uuid())
  brandId         String?   @map("brand_id")
  userId          String    @map("user_id")
  input           String
  inputMode       String    @map("input_mode")
  engine          String
  provider        String
  model           String
  visibilityScore Int?      @map("visibility_score")
  sentiment       String?
  sentimentScore  Float?    @map("sentiment_score")
  summary         String?
  recommendations Json?     @default("[]")
  rawResponse     Json?     @map("raw_response")
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("analysis_results")
}

model CompetitorAnalysis {
  id          String   @id @default(uuid())
  brandId     String?  @map("brand_id")
  userId      String   @map("user_id")
  primaryUrl  String   @map("primary_url")
  competitors Json     @default("[]")
  summary     String?
  rawResponse Json?    @map("raw_response")
  createdAt   DateTime @default(now()) @map("created_at")

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("competitor_analyses")
}

model RecommendationHistory {
  id              String   @id @default(uuid())
  brandId         String   @map("brand_id")
  userId          String   @map("user_id")
  recommendations Json     @default("[]")
  summary         String?
  basedOnCount    Int      @default(0) @map("based_on_count")
  createdAt       DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("recommendation_history")
}

model SeoAuditResult {
  id           String   @id @default(uuid())
  brandId      String?  @map("brand_id")
  userId       String   @map("user_id")
  url          String
  overallScore Float    @map("overall_score")
  results      Json     @default("{}")
  cachedAt     DateTime @default(now()) @map("cached_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brandId])
  @@index([url])
  @@index([expiresAt])
  @@map("seo_audit_results")
}

model LlmsTxtVersion {
  id          String   @id @default(uuid())
  brandId     String   @map("brand_id")
  userId      String   @map("user_id")
  llmsTxt     String   @map("llms_txt")
  llmsFullTxt String   @map("llms_full_txt")
  inputData   Json     @default("{}") @map("input_data")
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("llms_txt_versions")
}

model WeeklyReview {
  id         String   @id @default(uuid())
  brandId    String   @map("brand_id")
  userId     String   @map("user_id")
  weekNumber Int      @map("week_number")
  year       Int
  weekStart  DateTime @map("week_start") @db.Date
  weekEnd    DateTime @map("week_end") @db.Date
  metrics    Json     @default("{}")
  markdown   String?
  createdAt  DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, year, weekNumber])
  @@index([brandId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("weekly_reviews")
}

model WebhookDeliveryLog {
  id            String    @id @default(uuid())
  alertEventId  String    @map("alert_event_id")
  alertRuleId   String    @map("alert_rule_id")
  url           String
  status        String    @default("pending")
  httpStatus    Int?      @map("http_status")
  attempts      Int       @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  nextRetryAt   DateTime? @map("next_retry_at")
  responseBody  String?   @map("response_body")
  error         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([alertEventId])
  @@index([alertRuleId])
  @@index([status])
  @@index([nextRetryAt])
  @@map("webhook_delivery_logs")
}

model CitationSnapshot {
  id              String   @id @default(uuid())
  projectId       String   @map("project_id")
  scanDate        DateTime @map("scan_date") @db.Date
  engine          String   @default("all")
  category        String   @default("all")
  language        String   @default("all")
  totalPrompts    Int      @default(0) @map("total_prompts")
  brandCitations  Int      @default(0) @map("brand_citations")
  citationRate    Float    @default(0) @map("citation_rate")
  avgPosition     Float?   @map("avg_position")
  avgVisibility   Float    @default(0) @map("avg_visibility")
  avgSentiment    Float    @default(0) @map("avg_sentiment")
  competitorRates Json     @default("{}") @map("competitor_rates")
  createdAt       DateTime @default(now()) @map("created_at")

  brand Brand? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, scanDate, engine, category, language])
  @@index([projectId])
  @@index([scanDate(sort: Desc)])
  @@index([engine])
  @@map("citation_snapshots")
}

model KeywordRanking {
  id                String   @id @default(uuid())
  brandId           String   @map("brand_id")
  keyword           String
  url               String?
  position          Int      @default(0)
  searchVolume      Int      @default(0) @map("search_volume")
  intent            String?
  aiOverviewPresent Boolean  @default(false) @map("ai_overview_present")
  aiOverviewCited   Boolean  @default(false) @map("ai_overview_cited")
  createdAt         DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, keyword, createdAt(sort: Desc)])
  @@index([brandId])
  @@index([keyword])
  @@index([createdAt(sort: Desc)])
  @@index([position])
  @@map("keyword_rankings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 1 — Multi-tenancy (T07): Organization → Workspace → Brand hierarchy.
// Re-introduced 2026-05-13 as additive-only PR 7.1.
// FK on existing models (Brand.workspaceId etc.) are NULLABLE until backfill
// migration runs. NOT NULL enforcement happens in PR 7.7 post-backfill.
// See docs/enterprise-roadmap/02-fase-1-workspace-audit.md.
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id      String @id @default(uuid())
  name    String
  slug    String @unique
  ownerId String @map("owner_id")

  stripeCustomerId String?   @map("stripe_customer_id")
  stripeSubId      String?   @map("stripe_sub_id")
  plan             String    @default("free")
  status           String    @default("active")
  currentPeriodEnd DateTime? @map("current_period_end")

  logoUrl      String? @map("logo_url")
  primaryColor String  @default("#6366f1") @map("primary_color")

  defaultWorkspaceId String? @map("default_workspace_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  workspaces Workspace[]
  members    OrganizationMember[]
  auditLogs  AuditLog[]
  apiKeys    ApiKey[]
  brands     Brand[]

  @@index([ownerId])
  @@index([slug])
  @@index([deletedAt])
  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           String   @default("member") // owner | admin | billing | member
  invitedBy      String?  @map("invited_by")
  joinedAt       DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_members")
}

model Workspace {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  slug           String
  description    String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  brands       Brand[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("viewer") // owner | admin | editor | viewer
  invitedBy   String?  @map("invited_by")
  joinedAt    DateTime @default(now()) @map("joined_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fase 1 — Audit log (T08): append-only compliance trail.
// RLS policy in migration SQL enforces no UPDATE / no DELETE.
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  workspaceId    String? @map("workspace_id")

  actorId       String  @map("actor_id")
  actorType     String  @default("user") @map("actor_type") // user | api_key | system
  actorApiKeyId String? @map("actor_api_key_id")

  action       String
  resourceType String  @map("resource_type")
  resourceId   String? @map("resource_id")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  metadata  Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEW: GSC Performance — Google Search Console data sync
// ─────────────────────────────────────────────────────────────────────────────
model GscPerformance {
  id          String   @id @default(uuid())
  brandId     String   @map("brand_id")
  date        DateTime @db.Date
  query       String?
  page        String?
  country     String   @default("all")
  device      String   @default("all")
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, date, query, page, country, device])
  @@index([brandId, date(sort: Desc)])
  @@index([brandId, query])
  @@index([brandId, position])
  @@map("gsc_performance")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEW: Keyword Research — DataForSEO enriched keyword data
// ─────────────────────────────────────────────────────────────────────────────
model KeywordResearch {
  id                String   @id @default(uuid())
  brandId           String   @map("brand_id")
  keyword           String
  searchVolume      Int      @default(0) @map("search_volume")
  competition       Float    @default(0)
  cpc               Float    @default(0)
  trend             Json     @default("[]")
  intent            String?
  difficulty        Int?     @map("keyword_difficulty")
  aiOverviewPresent Boolean  @default(false) @map("ai_overview_present")
  top10Domains      Json     @default("[]") @map("top_10_domains")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, keyword])
  @@index([brandId])
  @@index([searchVolume(sort: Desc)])
  @@index([intent])
  @@map("keyword_research")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEW: Scraper Config — Per-brand scraping settings (internal calibration)
// ─────────────────────────────────────────────────────────────────────────────
model ScraperConfig {
  id              String   @id @default(uuid())
  brandId         String   @map("brand_id")
  engine          String
  promptText      String   @map("prompt_text")
  language        String   @default("en")
  market          String   @default("global")
  country         String   @default("us")
  isActive        Boolean  @default(true) @map("is_active")
  runFrequency    String   @default("daily") @map("run_frequency")
  lastRunAt       DateTime? @map("last_run_at")
  lastRunStatus   String?  @map("last_run_status")
  lastRunDuration Int?     @map("last_run_duration_ms")
  costCredits     Float    @default(0) @map("cost_credits")
  successRate     Float    @default(0) @map("success_rate")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, engine, promptText(191)])
  @@index([brandId])
  @@index([engine])
  @@index([isActive])
  @@map("scraper_configs")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEW: Report Template — Client report templates (weekly/monthly/30-60-90)
// ─────────────────────────────────────────────────────────────────────────────
model ReportTemplate {
  id            String   @id @default(uuid())
  brandId       String   @map("brand_id")
  name          String
  type          String   // weekly, monthly, 30day, 60day, 90day, custom
  language      String   @default("en")
  sections      Json     @default("[]")
  includeCharts Boolean  @default(true) @map("include_charts")
  includeTables Boolean  @default(true) @map("include_tables")
  includeRawData Boolean @default(false) @map("include_raw_data")
  logoUrl       String?  @map("logo_url")
  primaryColor  String   @default("#6366f1") @map("primary_color")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([type])
  @@map("report_templates")
}

// ─────────────────────────────────────────────────────────────────────────────
// NEW: Report Delivery — Track report generation and delivery to clients
// ─────────────────────────────────────────────────────────────────────────────
model ReportDelivery {
  id              String   @id @default(uuid())
  brandId         String   @map("brand_id")
  templateId      String?  @map("template_id")
  type            String   // weekly, monthly, 30day, 60day, 90day
  language        String   @default("en")
  periodStart     DateTime @map("period_start") @db.Date
  periodEnd       DateTime @map("period_end") @db.Date
  generatedAt     DateTime @default(now()) @map("generated_at")
  generatedBy     String   @map("generated_by")
  format          String   @default("pdf")
  fileUrl         String?  @map("file_url")
  sentTo          String?  @map("sent_to")
  sentAt          DateTime? @map("sent_at")
  status          String   @default("generated")
  metricsSnapshot Json     @default("{}") @map("metrics_snapshot")
  scoreDelta      Json     @default("{}") @map("score_delta")
  createdAt       DateTime @default(now()) @map("created_at")

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([type])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@map("report_deliveries")
}

model AiConversation {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  brandId     String?  @map("brand_id")
  agentType   String   @default("brand_monitor") @map("agent_type")
  title       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages    AiMessage[]
  brand       Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([brandId])
  @@index([agentType])
  @@index([updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String
  content        String
  providerUsed   String?  @map("provider_used")
  latencyMs      Int?     @map("latency_ms")
  tokensUsed     Int?     @map("tokens_used")
  costEstimate   Float?   @map("cost_estimate")
  contextData    Json?    @default("{}") @map("context_data")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@map("ai_messages")
}

// AI Cost Monitor - Comprehensive cost tracking and budget management
model AiCostLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  brandId        String?  @map("brand_id")
  provider       String   // gemini, chatgpt, perplexity, claude, etc.
  model          String?  // specific model used (gemini-2.0-flash, claude-sonnet-4-20250514, etc.)
  agentType      String?  @map("agent_type") // brand_monitor, competitor_analyst, etc.
  conversationId String?  @map("conversation_id")
  
  // Usage metrics
  inputTokens    Int      @default(0) @map("input_tokens")
  outputTokens   Int      @default(0) @map("output_tokens")
  totalTokens    Int      @default(0) @map("total_tokens")
  costUsd        Float    @default(0) @map("cost_usd")
  costCredits    Float    @default(0) @map("cost_credits")
  latencyMs      Int?     @map("latency_ms")
  
  // Request metadata
  endpoint       String?  // API endpoint used
  success        Boolean  @default(true)
  errorMessage   String?  @map("error_message")
  cached         Boolean  @default(false)
  
  // Budget tracking
  budgetAlert    Boolean  @default(false) @map("budget_alert") // triggered budget alert
  
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([brandId])
  @@index([provider])
  @@index([agentType])
  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([brandId, createdAt(sort: Desc)])
  @@map("ai_cost_logs")
}

// AI Budget configuration per user/brand
model AiBudget {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  brandId         String?  @map("brand_id")
  
  // Budget settings
  monthlyLimitUsd Float    @default(100) @map("monthly_limit_usd")
  dailyLimitUsd   Float?   @map("daily_limit_usd")
  alertThreshold  Float    @default(0.8) @map("alert_threshold") // 80% default
  
  // Provider-specific limits
  providerLimits  Json     @default("{}") @map("provider_limits") // {"gemini": 50, "claude": 30}
  
  // Tracking
  currentMonthSpend Float  @default(0) @map("current_month_spend")
  currentDaySpend   Float  @default(0) @map("current_day_spend")
  lastAlertSent     DateTime? @map("last_alert_sent")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([userId, brandId])
  @@index([userId])
  @@index([brandId])
  @@map("ai_budgets")
}
