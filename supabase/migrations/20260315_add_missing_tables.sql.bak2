CREATE POLICY "archives_view" ON research_archives FOR SELECT USING (auth.uid() = user_id);
CREATE POLICY "archives_insert" ON research_archives FOR INSERT WITH CHECK (auth.uid() = user_id);
CREATE POLICY "archives_update" ON research_archives FOR UPDATE USING (auth.uid() = user_id);
CREATE POLICY "archives_delete" ON research_archives FOR DELETE USING (auth.uid() = user_id);

