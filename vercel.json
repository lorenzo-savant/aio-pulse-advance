{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["arn1"],
  "crons": [
    {
      "path": "/api/cron/monitoring",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/monitoring",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/monitoring",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/aeo-bridge",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/weekly-review",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/geo-analysis",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/cron/gsc-sync",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/brightdata-sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/keyword-refresh",
      "schedule": "0 6 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://aio-pulse.com"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        },
        {
          "key": "Vary",
          "value": "Origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ]
}
